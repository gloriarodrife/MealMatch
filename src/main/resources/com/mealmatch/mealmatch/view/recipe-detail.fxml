<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1" prefHeight="400.0"
            prefWidth="600.0"
            xmlns="http://javafx.com/javafx/17"
            fx:controller="com.mealmatch.mealmatch.controller.RecipeDetailController">
    <children>
        <Label fx:id="titleLabel" layoutX="50.0" layoutY="50.0" text="Loading title...">
            <font>
                <Font name="System Bold" size="24.0"/>
            </font>
        </Label>
        <Button layoutX="20.0" layoutY="20.0" text="X" onAction="#handleBack"/>
    </children>
</AnchorPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml/1" prefHeight="720.0" prefWidth="1080.0" styleClass="main-container"
            xmlns="http://javafx.com/javafx/21" fx:controller="com.mealmatch.mealmatch.controller.HelloController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="30"
              style="-fx-border-color: #ddd; -fx-border-width: 0 0 1 0; -fx-background-color: white;">
            <padding>
                <Insets bottom="15" left="30" right="30" top="15"/>
            </padding>
            <Label style="-fx-font-size: 22; -fx-font-weight: bold;" text="Meal Match"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="searchRecipe" prefWidth="250" promptText="Search recipes..." styleClass="search-field"/>
        </HBox>
    </top>
    <left>
        <VBox prefWidth="200" spacing="15" style="-fx-background-color: #f8f9fa;">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20"/>
            </padding>
            <Label style="-fx-font-weight: bold;" text="CATEGORIES"/>
            <Hyperlink onAction="#handleCategoryAction" text="All Recipes"/>
            <Hyperlink onAction="#handleCategoryAction" text="Breakfast"/>
            <Hyperlink onAction="#handleCategoryAction" text="Main Courses"/>
            <Hyperlink onAction="#handleCategoryAction" text="Soups"/>
            <Separator/>
            <Label style="-fx-font-weight: bold;" text="DIETARY"/>
            <CheckBox fx:id="checkVegetarian" text="Vegetarian" onAction="#handleDietaryFilter"/>
            <CheckBox fx:id="checkVegan" text="Vegan" onAction="#handleDietaryFilter"/>
            <CheckBox fx:id="checkGlutenFree" text="Gluten Free" onAction="#handleDietaryFilter"/>
        </VBox>
    </left>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: white;">
            <FlowPane fx:id="recipeGrid" hgap="25" vgap="25">
                <padding>
                    <Insets bottom="30" left="30" right="30" top="30"/>
                </padding>
            </FlowPane>
        </ScrollPane>
    </center>
</BorderPane>
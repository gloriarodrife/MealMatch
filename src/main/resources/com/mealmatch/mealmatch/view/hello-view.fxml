<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<BorderPane xmlns:fx="http://javafx.com/fxml/1" prefHeight="720.0" prefWidth="1080.0" styleClass="main-container"
            xmlns="http://javafx.com/javafx/21" fx:controller="com.mealmatch.mealmatch.controller.HelloController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="30.0"
              style="-fx-border-color: #ddd; -fx-border-width: 0 0 1 0; -fx-background-color: white;">
            <padding>
                <Insets bottom="20" left="40" right="180" top="20"/>
            </padding>
            <Label style="-fx-font-size: 28; -fx-font-weight: 900; -fx-text-fill: #2c3e50;" text="Meal Match"/>

            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="searchRecipe" prefWidth="300" prefHeight="32" promptText="Search recipes..."
                       styleClass="search-field"/>
            <Button onAction="#onUserButtonClick"
                    prefWidth="32" prefHeight="32" minWidth="32" minHeight="32"
                    style="-fx-background-color: transparent; -fx-border-color: #c04848; -fx-border-width: 1.5; -fx-border-radius: 8; -fx-cursor: hand; -fx-padding: 0;">
                <graphic>
                    <SVGPath
                            content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
                            style="-fx-fill: #c04848;"
                    />
                </graphic>
            </Button>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="200" spacing="15" style="-fx-background-color: #f8f9fa;">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20"/>
            </padding>
            <Label style="-fx-font-weight: bold; -fx-text-fill: #c04848;" text="CATEGORIES"/>
            <Hyperlink onAction="#handleCategoryAction" text="All Recipes"
                       style="-fx-text-fill: #4a4a4a; -fx-underline: false; -fx-focus-color: transparent; -fx-faint-focus-color: transparent;"/>
            <Hyperlink onAction="#handleCategoryAction" text="Breakfast"
                       style="-fx-text-fill: #4a4a4a; -fx-underline: false; -fx-focus-color: transparent; -fx-faint-focus-color: transparent;"/>
            <Hyperlink onAction="#handleCategoryAction" text="Main Courses"
                       style="-fx-text-fill: #4a4a4a; -fx-underline: false; -fx-focus-color: transparent; -fx-faint-focus-color: transparent;"/>
            <Hyperlink onAction="#handleCategoryAction" text="Soups"
                       style="-fx-text-fill: #4a4a4a; -fx-underline: false; -fx-focus-color: transparent; -fx-faint-focus-color: transparent;"/>
            <Separator/>
            <Label style="-fx-font-weight: bold; -fx-text-fill: #c04848;" text="DIETARY"/>
            <CheckBox fx:id="checkVegetarian" text="Vegetarian" onAction="#applyFilters"/>
            <CheckBox fx:id="checkVegan" text="Vegan" onAction="#applyFilters"/>
            <CheckBox fx:id="checkGlutenFree" text="Gluten Free" onAction="#applyFilters"/>
            <Separator/>
            <Label style="-fx-font-weight: bold; -fx-text-fill: #c04848;" text="DIFFICULTY"/>
            <CheckBox fx:id="checkEasy" text="Easy" onAction="#applyFilters"/>
            <CheckBox fx:id="checkIntermediate" text="Intermediate" onAction="#applyFilters"/>
        </VBox>
    </left>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: white;">
            <FlowPane fx:id="recipeGrid" hgap="25" vgap="25">
                <padding>
                    <Insets bottom="30" left="30" right="30" top="30"/>
                </padding>
            </FlowPane>
        </ScrollPane>
    </center>
</BorderPane>